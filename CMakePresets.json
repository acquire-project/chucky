{
  "version": 6,
  "configurePresets": [
    {
      "name": "default",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "docker",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-I/usr/local/cuda/include",
        "CMAKE_CXX_FLAGS": "-I/usr/local/cuda/include"
      }
    }
  ]
}
